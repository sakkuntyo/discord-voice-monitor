{
  "name": "vencord-electron-voice-monitor",
  "version": "0.1.0",
  "private": true,
  "description": "Electron viewer for Vencord voice participants and speaking status",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win portable zip"
  },
  "build": {
    "appId": "com.sakkuntyo.discordvoicemonitor",
    "productName": "Discord Voice Monitor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        "portable",
        "zip"
      ]
    }
  },
  "dependencies": {
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "electron": "^36.3.1",
    "electron-builder": "^26.0.12"
  }
}
